# DriveScore — environment variables
# Copy this file to `.env.local` and fill in real values from your Supabase
# project (Project Settings → API). `.env.local` is gitignored — never commit
# real keys.

# Safe to expose to the browser (kept server-side in this milestone anyway):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SECRET — server-only. NO NEXT_PUBLIC_ prefix. Never used in client code,
# never shipped to the browser. Bypasses RLS, so guard it carefully.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Seed accounts (M2b-1) ────────────────────────────────────────────────
# `npm run db:seed` creates these three demo logins (email pre-confirmed).
# Used only by the seed script — not by the running app.
SEED_ADMIN_EMAIL=admin@DriveScore.test
SEED_ADMIN_PASSWORD=change-me-admin
SEED_TEACHER_EMAIL=teacher@DriveScore.test
SEED_TEACHER_PASSWORD=change-me-teacher
SEED_STUDENT_EMAIL=student@DriveScore.test
SEED_STUDENT_PASSWORD=change-me-student

# ── AI features (offline scripts only) ──────────────────────────────────────
# Anthropic — used by generate-ai-questions.mjs AND the Tamil translation agent.
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI — used ONLY by the Tamil translation pipeline for embeddings.
# Model: text-embedding-3-small (1536 dims). This constant is the single
# source of truth in lib/tamil/validation-config.ts — do not change the
# dimension here without updating it there.
OPENAI_API_KEY=your-openai-api-key

# ── Language-lock demo students (migration 0019) ─────────────────────────────
# Used by: scripts/seed-language-demo.ts + e2e/language-lock.spec.ts
# Run: npm run db:seed-language-demo  (after applying migrations 0017–0019)
SEED_LANG_EN_EMAIL=student.english@DriveScore.test
SEED_LANG_EN_PASSWORD=change-me-en
SEED_LANG_TA_EMAIL=student.tamil@DriveScore.test
SEED_LANG_TA_PASSWORD=change-me-ta
SEED_LANG_NULL_EMAIL=student.gate@DriveScore.test
SEED_LANG_NULL_PASSWORD=change-me-gate

# ── Tamil translation pipeline setup ─────────────────────────────────────────
# 1. Apply migrations: 0017_tamil_translation.sql, 0018_tamil_embedding_nullable.sql,
#                      0019_language_lock.sql
# 2. Seed glossary:   npm run db:seed-glossary
# 3. Seed knowledge:  npm run db:seed-knowledge
# 4. Seed demo:       npm run db:seed-language-demo
# 5. Translate:       npm run translate:tamil -- --subject Physics --status none --limit 50
# 6. Test:            npm run test:tamil
