# SynapTest — environment variables
# Copy this file to `.env.local` and fill in real values from your Supabase
# project (Project Settings → API). `.env.local` is gitignored — never commit
# real keys.

# Safe to expose to the browser (kept server-side in this milestone anyway):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SECRET — server-only. NO NEXT_PUBLIC_ prefix. Never used in client code,
# never shipped to the browser. Bypasses RLS, so guard it carefully.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Seed accounts (M2b-1) ────────────────────────────────────────────────
# `npm run db:seed` creates these three demo logins (email pre-confirmed).
# Used only by the seed script — not by the running app.
SEED_ADMIN_EMAIL=admin@synaptest.test
SEED_ADMIN_PASSWORD=change-me-admin
SEED_TEACHER_EMAIL=teacher@synaptest.test
SEED_TEACHER_PASSWORD=change-me-teacher
SEED_STUDENT_EMAIL=student@synaptest.test
SEED_STUDENT_PASSWORD=change-me-student
